    <media>
      <medium format="image">
        <type>IMAGE_PRIMARY</type>
        <url>https://images.example.com/style-001-wht.jpg</url>
        <thumbUrl>https://images.example.com/style-001-wht_thumb.jpg</thumbUrl>
