        <wholesalePrice>25.00</wholesalePrice>
        <net>false</net>
      </price>
    </prices>

    <sizes>
      <size>
        <name>M</name>
        <sortCode>2</sortCode>
        <prePackUnitCount>1</prePackUnitCount>
        <eanCode>8712345678912</eanCode>
        <stockLevels>
          <stockLevel>
            <startDate>1980-01-01</startDate>
