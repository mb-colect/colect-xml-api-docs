<?xml version="1.0" encoding="UTF-8"?>
<!--
  Sizes & Stock sub-feed input document — example.
  Hourly stock refresh for one style/color, including current stock + future restock dates.
  This document REPLACES the entire <sizes> block for each included product.

  Validates against schema/snapshots/2026-05-06/ProductSizes_Feed_XSD.xsd
-->
<products>

  <product>
    <uniqueId>STYLE-001</uniqueId>
    <colorCode>BLK</colorCode>
    <sizes>
      <size>
        <name>S</name>
        <sortCode>1</sortCode>
        <prePackUnitCount>1</prePackUnitCount>
        <eanCode>8712345678901</eanCode>
        <stockLevels>
          <stockLevel>
            <startDate>1980-01-01</startDate>
            <quantity>110</quantity>
          </stockLevel>
        </stockLevels>
      </size>
      <size>
        <name>M</name>
        <sortCode>2</sortCode>
        <prePackUnitCount>1</prePackUnitCount>
        <eanCode>8712345678902</eanCode>
        <stockLevels>
          <stockLevel>
            <startDate>1980-01-01</startDate>
            <quantity>165</quantity>
          </stockLevel>
          <!-- Future restock arriving June 1 -->
          <stockLevel>
            <startDate>2026-06-01</startDate>
            <quantity>500</quantity>
          </stockLevel>
        </stockLevels>
      </size>
      <size>
        <name>L</name>
        <sortCode>3</sortCode>
        <prePackUnitCount>1</prePackUnitCount>
        <eanCode>8712345678903</eanCode>
        <stockLevels>
          <stockLevel>
            <startDate>1980-01-01</startDate>
            <quantity>132</quantity>
          </stockLevel>
        </stockLevels>
      </size>
      <size>
        <name>XL</name>
        <sortCode>4</sortCode>
        <prePackUnitCount>1</prePackUnitCount>
        <eanCode>8712345678904</eanCode>
        <accessCode>PRO</accessCode>
        <stockLevels>
          <stockLevel>
            <startDate>1980-01-01</startDate>
            <quantity>0</quantity>
          </stockLevel>
        </stockLevels>
        <replenishmentDate>2026-06-15</replenishmentDate>
      </size>
    </sizes>
  </product>

  <!-- Example with customerSizeNaming (v1.5) — internal "M" labelled "MEDIUM" for one customer group -->
  <product>
    <uniqueId>STYLE-001</uniqueId>
    <colorCode>WHT</colorCode>
    <sizes>
      <size>
        <name>M</name>
        <sortCode>2</sortCode>
        <prePackUnitCount>1</prePackUnitCount>
        <eanCode>8712345678912</eanCode>
        <customerSizeNaming>
          <code>WHOLESALE_EU</code>
          <sizeName>MEDIUM</sizeName>
        </customerSizeNaming>
        <customerSizeNaming>
          <code>RETAIL</code>
          <sizeName>M</sizeName>
        </customerSizeNaming>
        <stockLevels>
          <stockLevel>
            <startDate>1980-01-01</startDate>
            <quantity>200</quantity>
          </stockLevel>
        </stockLevels>
      </size>
    </sizes>
  </product>

</products>
